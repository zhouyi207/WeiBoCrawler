{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ysscrawler",
  "version": "0.1.1",
  "identifier": "com.zhouyi31.ysscrawler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ysscrawler",
        "width": 1500,
        "height": 900,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4MjAzRTU0MkRBMDFFClJXUWVvQzFVUGlCWUFOTVRkQkt2NzdQTlcreGxKeU4zQVI2Mkp1WXI3YS9VQXEvSEp3VlZ3MU5uCg==",
      "endpoints": [
        "https://github.com/zhouyi207/WeiBoCrawler/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
